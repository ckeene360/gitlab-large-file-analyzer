# GitLab API Configuration
# Copy this file to .env and fill in your actual values

# Required: Your GitLab personal access token
# Get it from: GitLab -> Settings -> Access Tokens
# Required scopes: read_api, read_repository
GITLAB_TOKEN=your_gitlab_token_here

# Optional: GitLab instance URL (default: https://gitlab.com)
# Uncomment and modify if using a self-hosted GitLab instance
# GITLAB_URL=https://gitlab.company.com

# Optional: GitLab group URL or group name to analyze
# Examples:
# GITLAB_GROUP_URL=https://gitlab.com/powerschoolgroup
# GITLAB_GROUP_URL=powerschoolgroup
# GITLAB_GROUP_ID=93415483  # PowerSchool Group ID
# GITLAB_GROUP_URL=https://gitlab.com/powerschoolgroup
GITLAB_GROUP_ID=93415483

# Optional: Default analysis threshold in MB (default: 50.0)
# Files larger than this will be flagged for analysis
# THRESHOLD_MB=50.0